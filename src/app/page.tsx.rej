+                  <div className="bg-white dark:bg-[#1e293b] p-5 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-4">
+                    <span className={`text-2xl w-12 h-12 flex items-center justify-center rounded-xl ${itemStatusTab === 'Active' ? 'bg-emerald-50 dark:bg-emerald-900/20' : 'bg-rose-50 dark:bg-rose-900/20'}`}>{itemStatusTab === 'Active' ? 'â‰¡Æ’Ă…â•–âˆ©â••Ă…' : 'â‰¡Æ’Ă´Âª'}</span>
+                          <td className="px-6 py-4">
+                            <span className="font-semibold text-sm text-slate-800 dark:text-slate-200">{item.productName}</span>
+                          </td>
+                          <td className="px-6 py-4">
+                            <span className="font-mono text-xs text-slate-500 dark:text-slate-400 tracking-wide">{item.imeiNo}</span>
+                          </td>
+                          <td className="px-6 py-4 font-mono font-semibold text-sm text-slate-700 dark:text-slate-300">Î“Ă©â•£{(item.purchasePrice || 0).toLocaleString()}</td>
+                          {itemStatusTab === 'Inactive' && (
+                            <td className="px-6 py-4 font-mono font-semibold text-sm text-emerald-600 dark:text-emerald-400">Î“Ă©â•£{(item.sellingPrice || 0).toLocaleString()}</td>
+                          )}
+                          <td className="px-6 py-4 text-sm text-slate-500">{itemStatusTab === 'Active' ? (item.purchaseDate || 'Î“Ă‡Ă¶') : (item.soldDate || 'Î“Ă‡Ă¶')}</td>
+                          <td className="px-6 py-4 text-right">
+                            <span className={`text-[10px] font-bold px-2 py-1 rounded uppercase tracking-tight ${itemStatusTab === 'Active' ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-400'}`}>
+                              {itemStatusTab === 'Active' ? 'Î“Â£Ă  In Stock' : 'â‰¡Æ’Ă´Âª Sold'}
+                            </span>
+                          </td>
+                        </tr>
+                      ));
+                    })()}
+                  </tbody>
+                </table>
+              </div>
             </div>
           </div>
         )}
       </main>
+
+      {/* Manual Cash Modal */}
+      {cashModalOpen && (
+        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm overflow-y-auto">
+          <div className="bg-white dark:bg-[#1e293b] rounded-2xl w-full max-w-md shadow-2xl overflow-hidden border border-slate-200 dark:border-slate-700 my-8">
+             <div className="p-6 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-indigo-50 dark:bg-indigo-900/20">
+               <h3 className="font-bold text-lg flex items-center gap-2">â‰¡Æ’Ă†â–‘ Manual Cash Entry</h3>
+               <button onClick={() => setCashModalOpen(false)} className="text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors cursor-pointer text-xl">Î“Â£Ă²</button>
+             </div>
+             <form onSubmit={handleAddCash} className="p-6 space-y-5">
+                <div className="flex gap-4 p-3 bg-slate-50 dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-700">
+                  <label className="flex-1 flex items-center gap-2 font-bold cursor-pointer justify-center text-sm">
+                    <input type="radio" className="accent-indigo-600" checked={cashType === 'Cash In'} onChange={() => setCashType('Cash In')} /> Debit (In)
+                  </label>
+                  <label className="flex-1 flex items-center gap-2 font-bold cursor-pointer justify-center text-sm">
+                    <input type="radio" className="accent-rose-600" checked={cashType === 'Cash Out'} onChange={() => setCashType('Cash Out')} /> Credit (Out)
+                  </label>
+                </div>
+                
+                <div className="grid grid-cols-2 gap-4">
+                   <div>
+                      <label className="block text-xs font-semibold mb-1 text-slate-500">Date</label>
+                      <input required type="date" value={cashForm.date} onChange={e => setCashForm({...cashForm, date: e.target.value})} className="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2 outline-none focus:border-indigo-500" />
+                   </div>
+                   <div>
+                      <label className="block text-xs font-semibold mb-1 text-slate-500">Amount (Î“Ă©â•£)</label>
+                      <input required type="number" min="0" value={cashForm.amount} onChange={e => setCashForm({...cashForm, amount: e.target.value})} placeholder="0.00" className="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2 outline-none focus:border-indigo-500 font-mono" />
+                   </div>
+                </div>
+
+                <div>
+                   <label className="block text-xs font-semibold mb-1 text-slate-500">Payment Mode</label>
+                   <select value={cashForm.mode} onChange={e => setCashForm({...cashForm, mode: e.target.value as any})} className="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2 outline-none focus:border-indigo-500 font-medium">
+                      <option value="Cash">Cash</option>
+                      <option value="UPI">UPI</option>
+                      <option value="Credit Card">Credit Card</option>
+                      <option value="Debit Card">Debit Card</option>
+                      <option value="Netbanking">Netbanking</option>
+                      <option value="Exchange">Exchange</option>
+                   </select>
+                </div>
+
+                <div className="grid grid-cols-1 gap-4 pt-2">
+                   <div>
+                      <label className="block text-xs font-semibold mb-1 text-slate-500">Giver Name</label>
+                      <input required type="text" value={cashForm.giverName} onChange={e => setCashForm({...cashForm, giverName: e.target.value})} placeholder="Who gave this amount?" className="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2 outline-none focus:border-indigo-500" />
+                   </div>
+                   <div>
+                      <label className="block text-xs font-semibold mb-1 text-slate-500">Receiver Name</label>
+                      <input required type="text" value={cashForm.receiverName} onChange={e => setCashForm({...cashForm, receiverName: e.target.value})} placeholder="Who received it?" className="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2 outline-none focus:border-indigo-500" />
+                   </div>
+                </div>
+
+                <div className="pt-6 border-t border-slate-100 dark:border-slate-800 flex gap-3">
+                   <button type="button" onClick={() => setCashModalOpen(false)} className="flex-1 px-4 py-3 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-xl font-medium transition-colors cursor-pointer">Cancel</button>
+                   <button type="submit" className="flex-1 px-4 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-bold transition-all shadow-lg shadow-indigo-500/20 cursor-pointer">Save Cash Entry</button>
+                </div>
+             </form>
+          </div>
+        </div>
+      )}
     </div>
   );
 };
